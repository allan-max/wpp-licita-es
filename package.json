{
  "name": "bot-licitacoes",
  "version": "1.0.0",
  "description": "Sistema de Automação de licitacoes por WhatsApp",
  "author": "Allan Iglesias",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.allan.botlicitacoes",
    "npmRebuild": false,
    "win": {
      "target": "nsis",
      "icon": "build/maestro-licita.ico"
    },
    "asarUnpack": [
      "node_modules/puppeteer-core/**"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "allan-max",
        "repo": "https://github.com/allan-max/wpp-licita-es"
      }
    ]
  },
  "dependencies": {
    "@wppconnect-team/wppconnect": "^1.30.0",
    "electron-updater": "^6.1.8",
    "express": "^4.22.2"
  },
  "devDependencies": {
    "electron": "30.0.0",
    "electron-builder": "^24.13.3"
  }
}
