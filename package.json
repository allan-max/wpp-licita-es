{
  "name": "maestro-licita",
  "version": "1.0.1",
  "description": "Sistema de Automação de licitacoes por WhatsApp",
  "author": "Allan Iglesias",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/allan-max/wpp-licita-es.git"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.allan.maestrolicita",
    "npmRebuild": false,
    "win": {
      "target": "nsis",
      "icon": "assets/maestro-licita.ico"
    },
    "extraResources": [
      {
        "from": "assets/publish",
        "to": "publish",
        "filter": ["**/*"]
      }
    ],
    "asarUnpack": [
      "node_modules/puppeteer-core/**"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "allan-max",
        "repo": "wpp-licita-es"
      }
    ]
  },
  "dependencies": {
    "@wppconnect-team/wppconnect": "^1.30.0",
    "electron-updater": "^6.1.8",
    "express": "^4.22.2",
    "node-machine-id": "^1.1.12"
  },
  "devDependencies": {
    "electron": "30.0.0",
    "electron-builder": "^24.13.3"
  }
}