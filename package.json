{
  "name": "bot-licitacoes",
  "version": "1.0.0",
  "description": "Sistema de Automação de WhatsApp",
  "author": "Allan Iglesias", 
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.seunome.botlicitacoes",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico" 
    },
    "asarUnpack": [
      "node_modules/puppeteer-core/**"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "seu_usuario_do_github",
        "repo": "nome_do_repositorio"
      }
    ]
  },
  "dependencies": {
    "@wppconnect-team/wppconnect": "^1.30.0",
    "express": "^4.19.2",
    "electron-updater": "^6.1.8"
  },
  "devDependencies": {
    "electron": "30.0.0", 
    "electron-builder": "^24.13.3"
  }
}